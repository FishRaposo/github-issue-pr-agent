# App General Settings
APP_NAME=github-issue-pr-agent
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database & cache (optional — service falls back to in-memory when unreachable).
# Use host.docker.internal from containers, or localhost from the host machine.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0

# Celery (optional — API runs the pipeline synchronously when no broker is set).
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# GitHub access: "mock" (offline default) or "real" (REST API; needs GITHUB_TOKEN).
GITHUB_MODE=mock
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=your-github-token

# LLM planning (optional — planner simulates deterministically without keys).
PLANNER_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Agent behaviour
SANDBOX_REPO_PATH=demo_repo
# Comma-separated glob allowlist / blocklist for editable paths.
ALLOWED_PATHS=*.py,*.txt,*.md,*.yaml,*.yml,*.json,*.toml,*.cfg,*.ini
BLOCKED_PATHS=.github/**,.env,.env.*,Makefile,pyproject.toml,docker-compose.yml,requirements.txt,alembic.ini,**/secrets/**
PROTECTED_BRANCHES=main,master
# When true, a draft PR opens automatically once tests pass (skips the human gate).
AUTO_APPROVE=false
